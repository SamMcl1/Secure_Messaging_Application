# Copy this to .env and fill in your values
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

# Required — no fallback; app will refuse to start without this
SECRET_KEY=change-this-to-a-long-random-secret

# Debug mode — set to 1 for local development only; never in production
FLASK_DEBUG=0

# CORS — exact origin the web client is served from.
# For local development, use an explicit dev server origin such as http://localhost:3000.
# Do not use "null" for file:// development; it can also match other null-origin contexts.
# Leave empty to deny all cross-origin requests.
ALLOWED_ORIGIN=

# Supabase project URL (e.g. https://xyzcompany.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe for client-side use)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server-only — never expose this)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Direct PostgreSQL connection string (from Supabase -> Settings -> Database -> Connection string -> Python)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Blockchain
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-infura-project-id
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
DEPLOYER_PRIVATE_KEY=your-deployer-private-key
